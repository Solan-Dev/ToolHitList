# Power Apps Code App – .gitignore

# Node / npm
node_modules/
.cache/

# Build output
dist/
out/

# power.config.json IS committed — it contains no secrets (env binding via pac env select)

# Environment-specific values
.env
.env.*
config/local.json

# PAC CLI auth profiles (per-machine, never commit)
.pac/

# VS Code local overrides
.vscode/settings.json
.vscode/launch.json

# OS
.DS_Store
Thumbs.db

# Power Apps test output
TestOutput/
