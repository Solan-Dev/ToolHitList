# Power Platform / PCF .gitignore

# Node / npm
node_modules/
.cache/

# Build output
dist/
out/

# Power Apps SDK generated files (regenerated by pac code init / add connection)
app/power.config.json

# Environment-specific values
.env
.env.*
config/local.json

# PAC CLI auth profiles (per-machine, never commit)
.pac/

# VS Code local overrides
.vscode/settings.json
.vscode/launch.json

# OS
.DS_Store
Thumbs.db

# Power Apps test output
TestOutput/
